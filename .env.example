# ============================================================
#  BTC Strength Bot v3 — Environment Variables
#  Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# ── WhatsApp (Whapi.cloud) ──────────────────────────────────
WHATSAPP_NUMBER=255753151096
WHAPI_TOKEN=your_whapi_channel_token_here

# ── News (optional — free signup at cryptopanic.com) ────────
CRYPTOPANIC_API_KEY=

# ── Django ──────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# ── Scan Settings ───────────────────────────────────────────
TOP_GAINERS_COUNT=25
MIN_GAIN_PERCENT=5.0
SCAN_INTERVAL_MINUTES=15
TIMEFRAME=1h
CANDLE_LIMIT=80

# ── Signal Thresholds ───────────────────────────────────────
RSI_OVERBOUGHT=70
RSI_BUY_MIN=42
RSI_BUY_MAX=65
BTC_STRONG_THRESHOLD=60
BTC_WEAK_THRESHOLD=45
BTC_RSI_DANGER=72
EMA_DISTANCE_STRONG=2.0
EMA_DISTANCE_MODERATE=1.5
VOLUME_CLIMAX=3.0
VOLUME_STRONG=2.0
VOLUME_BUY_MIN=1.3

# ── Confluence thresholds (raised to 3.8 for higher accuracy) ──
MIN_SELL_CONFLUENCE=3.8
MIN_BUY_CONFLUENCE=3.8

# ── Risk Management ─────────────────────────────────────────
TP1_PCT=3.0
TP2_PCT=6.0
TP3_PCT=10.0
SL_PCT=2.0
TP1_CLOSE=33
TP2_CLOSE=33
TP3_CLOSE=34

# ── Alert Control ───────────────────────────────────────────
COOLDOWN_HOURS=2
BTC_UPDATE_EVERY_HOURS=4

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
